{
  "mcpServers": {
    "paperena": {
      "command": "python3",
      "args": ["server.py"],
      "cwd": "${CLAUDE_PROJECT_ROOT}/mcp-server",
      "env": {
        "PYTHONPATH": "${CLAUDE_PROJECT_ROOT}"
      },
      "description": "Paperena paper verification tools: parsing, segmentation, SymPy sandbox, arithmetic evaluation, and dataset access."
    }
  },
  "skills": {
    "directory": ".claude/skills"
  },
  "permissions": {
    "allow": [
      "mcp__paperena__parse_paper",
      "mcp__paperena__segment_paper",
      "mcp__paperena__run_sympy_sandbox_exec",
      "mcp__paperena__run_sympy_check",
      "mcp__paperena__safe_arithmetic_eval",
      "mcp__paperena__check_numeric_claim",
      "mcp__paperena__get_paper_from_dataset",
      "mcp__paperena__list_papers_in_dataset",
      "mcp__paperena__analyze_dataset_schema",
      "Bash(python3:*)",
      "Bash(cd:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(grep:*)",
      "Bash(wc:*)"
    ]
  }
}
